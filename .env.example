# Casper JSON-RPC endpoints (public CSPR.cloud defaults)
# Swap in a private CSPR.cloud endpoint for higher rate limits.
VITE_CASPER_TESTNET_RPC=https://node.testnet.cspr.cloud/rpc
VITE_CASPER_MAINNET_RPC=https://node.cspr.cloud/rpc

# Block explorers (used for account and deploy links)
VITE_CASPER_TESTNET_EXPLORER=https://testnet.cspr.live
VITE_CASPER_MAINNET_EXPLORER=https://cspr.live
