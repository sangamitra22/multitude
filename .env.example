# Casper JSON-RPC endpoints (public CSPR.cloud defaults)
# Swap in a private CSPR.cloud endpoint for higher rate limits.
VITE_CASPER_TESTNET_RPC=https://node.testnet.cspr.cloud/rpc
VITE_CASPER_MAINNET_RPC=https://node.cspr.cloud/rpc

# Block explorers (used for account and deploy links)
VITE_CASPER_TESTNET_EXPLORER=https://testnet.cspr.live
VITE_CASPER_MAINNET_EXPLORER=https://cspr.live

# Deployed Odra contract hashes (leave blank until you deploy)
# When blank, agent workflows fall back to x402 native-transfer attestations.
VITE_CASPER_TESTNET_VERUS_CONTRACT=
VITE_CASPER_TESTNET_SENTINEL_CONTRACT=
VITE_CASPER_TESTNET_QUORRA_CONTRACT=
VITE_CASPER_TESTNET_YIELD_CONTRACT=
VITE_CASPER_MAINNET_VERUS_CONTRACT=
VITE_CASPER_MAINNET_SENTINEL_CONTRACT=
VITE_CASPER_MAINNET_QUORRA_CONTRACT=
VITE_CASPER_MAINNET_YIELD_CONTRACT=

# x402 micropayment routing (recipient public key + motes per call)
VITE_CASPER_TESTNET_X402_RECIPIENT=
VITE_CASPER_TESTNET_X402_MOTES=42000000
VITE_CASPER_MAINNET_X402_RECIPIENT=
VITE_CASPER_MAINNET_X402_MOTES=42000000
